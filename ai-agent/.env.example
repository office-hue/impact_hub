ARTIFACTS_MODE=dual
CORE_CAPABILITY_ROUTING=1
CORE_CAPABILITY_TIMEOUT_MS=15000

# Drive OAuth (ha a saját Drive-od kvótáját használnád)
CORE_DRIVE_OAUTH_CLIENT=/absolute/path/to/drive-oauth-client.json
CORE_DRIVE_OAUTH_TOKEN=/absolute/path/to/drive-oauth-token.json
CORE_DRIVE_SHARED_DRIVE_ID=
CORE_DRIVE_SHARED_ROOT_ID=
CORE_DRIVE_SHARED_ROOT_SKIP=2

# Billingo cron (fallback, ha nincs crontab)
CORE_BILLINGO_CRON_ENABLED=0
CORE_BILLINGO_CRON_INTERVAL_MS=86400000
CORE_BILLINGO_CRON_INITIAL_DELAY_MS=300000
CORE_CHAIN_MAX_ITERATIONS=10
ADS_CAPI_BASE_URL=
ADS_CAPI_SHARED_SECRET=
ADS_DEFAULT_LANDING_URL=https://app.sharity.hu/impactshop/
ADS_DEFAULT_LANGUAGE=hu
ADS_DEFAULT_COUNTRY=HU
ADS_DEFAULT_PLATFORMS=meta,googleads,tiktok,youtube
ADS_BUDGET_MONTHLY_HUF=50000
ADS_EXECUTE_MODE=dry-run
ADS_MANAGEMENT_BASE_URL=
ADS_MANAGEMENT_API_KEY=
BILLINGO_API_BASE_URL=https://api.billingo.hu/v3
BILLINGO_API_KEY=
BILLINGO_COMPANY_ID=
BILLINGO_SYNC_ENDPOINTS=documents,partners,products
BILLINGO_PAGE_SIZE=50
BILLINGO_MAX_PAGES=10

# AI Memory Phase 0 (read-only retriever + manual logging)
AI_MEMORY_PHASE0_ENABLED=0
AI_MEMORY_DATABASE_URL=
AI_MEMORY_SCHEMA=ai_memory
AI_MEMORY_AUTO_MIGRATE=0
