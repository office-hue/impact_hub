{
  "name": "ai-agent",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/sync-knowledge-assets.js",
    "dev:api": "tsx -r tsconfig-paths/register apps/api-gateway/src/index.ts",
    "dev:agent": "tsx -r tsconfig-paths/register apps/ai-agent-core/src/index.ts",
    "dev:mvp": "tsx -r tsconfig-paths/register apps/dev-runner/src/index.ts",
    "core:worker": "tsx apps/core-worker/src/index.ts",
    "playwright:arukereso": "tsx tools/playwright/arukereso-runner.ts",
    "ingest:normalize": "tsx tools/ingest/normalizer.ts",
    "ingest:sync": "tsx tools/ingest/sync-from-impactshop.ts",
    "ingest:export": "tsx tools/ingest/export-coupons.ts",
    "guard:story": "tsx tools/guard/story-guard-report.ts",
    "diag:shops": "tsx tools/diagnostics/check-shops-registry.ts",
    "gmail:auth": "tsx tools/gmail/auth.ts",
    "gmail:promotions": "tsx tools/gmail/promotions-runner.ts",
    "drive:catalog": "tsx tools/drive/build-drive-catalog.ts",
    "lint": "tsc --noEmit",
    "test:core-capabilities": "node --import tsx tests/core-capabilities.test.ts",
    "test:decision": "node --import tsx tests/decision.test.ts",
    "test:dispatcher": "node --import tsx tests/dispatcher.test.ts",
    "test:billingo": "node --import tsx tests/billingo.test.ts",
    "test:gmail": "node --import tsx tests/gmail.test.ts",
    "test:approve": "node --import tsx tests/approve.test.ts",
    "test:smoke": "npm run test:decision && npm run test:dispatcher && npm run test:billingo && npm run test:gmail && npm run test:approve",
    "document:ingest": "tsx tools/excel/extract-runner.ts",
    "test:pivot": "node --import tsx tests/excel/pivot-normalizer.test.ts"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.0.4",
    "bullmq": "^5.9.2",
    "camelcase": "^9.0.0",
    "csv-parse": "^6.1.0",
    "decamelize": "^6.0.1",
    "discord.js": "^14.25.1",
    "docx": "^9.5.1",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^130.0.0",
    "ioredis": "^5.4.1",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "openai": "^4.76.3",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "pg": "^8.13.1",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "playwright": "^1.48.2",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.7.5",
    "@types/pg": "^8.10.2",
    "@types/uuid": "^9.0.8",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
